# .env.cloud — config de despliegue (NO se commitea)
# Todas las URLs de backend son PLANAS (server-only): las consume el BFF en
# runtime. NO usar NEXT_PUBLIC_ para backends (se inlinean en build).

AUTH_SERVICE_URL=https://auth.hagemsa.com

# Backends por bounded context (planas)
ACTIVOS_API_URL=https://api-bc02-activos.hagemsa.com
COMBUSTIBLE_API_URL=https://api-combustible-dev.hagemsa.com
COMERCIAL_API_URL=https://api-bc03-comercial.hagemsa.com/api
SOCIO_NEGOCIOS_API_URL=https://api-bc01-socio-negocio.hagemsa.com/api
CONFIGURACION_GENERAL_API_URL=https://bc14-cs-configuracion-general.hagemsa.com/api
# BC-04 Flota (completar con la URL real del backend de flota desplegado)
# FLOTA_API_URL=https://api-bc04-flota.hagemsa.com/api

# Fallback opcional (plana)
# API_GATEWAY_URL=https://api-gateway.hagemsa.com

NODE_ENV=production
