# .env.cloud.example
# Copiar a .env.cloud antes de desplegar:
#   cp .env.cloud.example .env.cloud
#
# Todas las URLs de backend son PLANAS (server-only): las consume el BFF
# (/api/<bc>/*) en runtime. NO usar NEXT_PUBLIC_ para backends (se inlinean en
# build y quedan undefined en el server de Cloud Run). Una variable por backend.

AUTH_SERVICE_URL=https://auth.hagemsa.com

# Backends por bounded context (planas)
ACTIVOS_API_URL=https://api-activos-dev.hagemsa.com
COMBUSTIBLE_API_URL=https://api-combustible-dev.hagemsa.com
COMERCIAL_API_URL=https://api-bc03-comercial.hagemsa.com/api/v1
FLOTA_API_URL=https://api-bc04-flota.hagemsa.com/api
SOCIO_NEGOCIOS_API_URL=https://api-bc01-socio-negocio.hagemsa.com/api
CONFIGURACION_GENERAL_API_URL=https://bc14-cs-configuracion-general.hagemsa.com/api

# Fallback opcional cuando falta la URL especifica de un BC (plana).
# API_GATEWAY_URL=https://api-gateway.hagemsa.com

NODE_ENV=production
