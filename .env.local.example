# =============================================================================
# Variables de entorno del frontend HAGEMSA ERP (local / desarrollo)
# =============================================================================
#
# COMO USAR:
#   1. Copiar este archivo a .env.local
#        cp .env.local.example .env.local
#   2. Reemplazar los valores con las URLs reales de tu entorno.
#   3. .env.local NUNCA se commitea (esta en .gitignore).
#
# =============================================================================
# ESTANDAR DE NAMING (importante, leelo)
# =============================================================================
#   - Las URLs de backend van SIN prefijo (variables PLANAS). Solo las consume
#     el servidor (Route Handlers de /api/*, middleware, server actions), que
#     inyecta el token desde la cookie httpOnly y reenvia al backend. El
#     navegador nunca pega directo a un backend ni ve estas URLs.
#   - NO usar NEXT_PUBLIC_ para URLs de backend: las NEXT_PUBLIC_* se "inlinean"
#     en build y quedan congeladas/undefined en el server de produccion
#     (Cloud Run inyecta env vars en runtime). Ademas expondrian la URL al JS.
#   - NEXT_PUBLIC_ queda reservado para config genuinamente publica del cliente
#     (hoy: ninguna URL de backend la usa).
#   - Una sola variable por backend: <BC>_API_URL.
# =============================================================================


# -----------------------------------------------------------------------------
# Auth Service
# -----------------------------------------------------------------------------
# URL del servicio de autenticacion. Los Route Handlers de /api/auth/* hablan
# con este backend y solo devuelven cookies httpOnly al cliente.
# Si corres el Auth Service local con `pnpm start:dev`, usar http://localhost:8080
AUTH_SERVICE_URL=https://auth.hagemsa.com

# Segundos antes del exp del access token para refrescarlo en el middleware.
# Default 60.
# JWT_ACCESS_REFRESH_THRESHOLD_SECONDS=60


# -----------------------------------------------------------------------------
# Backends por bounded context (todas PLANAS / server-only)
# -----------------------------------------------------------------------------
# Cada modulo consume su backend a traves del BFF (/api/<bc>/*). El Route
# Handler lee la URL de abajo en runtime e inyecta el bearer.

# BC-02 Activos (puerto propio del backend; NO 3000, que es el de Next)
ACTIVOS_API_URL=http://localhost:3001

# Combustible
COMBUSTIBLE_API_URL=http://localhost:3003

# BC-03 Gestion Comercial
COMERCIAL_API_URL=http://localhost:3000/api/v1

# BC-04 Flota
FLOTA_API_URL=http://localhost:8084/api

# BC-01 Socio de Negocios (sirve socios-de-negocio y asignaciones-personal)
SOCIO_NEGOCIOS_API_URL=http://localhost:8080/api

# BC-14 Configuracion General
CONFIGURACION_GENERAL_API_URL=http://localhost:4002/api


# -----------------------------------------------------------------------------
# API Gateway (opcional, PLANA)
# -----------------------------------------------------------------------------
# Si esta seteada, sirve de fallback cuando falta la URL especifica de un BC.
# Util cuando todo el trafico pasa por un gateway unico.
#
# API_GATEWAY_URL=http://localhost:8080
