# =============================================================================
# Variables de entorno del frontend HAGEMSA ERP
# =============================================================================
#
# COMO USAR:
#   1. Copiar este archivo a .env.local
#        cp .env.local.example .env.local
#   2. Reemplazar los valores con las URLs reales de tu entorno (local/staging).
#   3. El archivo .env.local NUNCA se commitea (esta en .gitignore).
#
# NAMING:
#   - NEXT_PUBLIC_*  -> visible para el navegador. Usar para URLs publicas
#                      (backends que el navegador consume directo).
#   - Sin prefijo    -> solo accesible desde el server (Route Handlers,
#                      middleware). Usar para secretos y URLs internas.
# =============================================================================


# -----------------------------------------------------------------------------
# Auth Service (server-only)
# -----------------------------------------------------------------------------
# URL del servicio de autenticacion HAGEMSA. El navegador NUNCA pega directo:
# los Route Handlers en src/app/api/auth/* hablan con este backend y solo
# devuelven cookies httpOnly al cliente.
#
# Por default apunta al Auth Service en produccion. Si estas corriendo
# el Auth Service localmente con `pnpm start:dev`, cambiar a:
#   AUTH_SERVICE_URL=http://localhost:8080
AUTH_SERVICE_URL=https://auth.hagemsa.com

# Segundos antes del exp del access token para refrescarlo en el middleware.
# Default 60.
# JWT_ACCESS_REFRESH_THRESHOLD_SECONDS=60


# -----------------------------------------------------------------------------
# Backends por bounded context
# -----------------------------------------------------------------------------
# Cada modulo consume su propio backend (microservicio). Si en el futuro hay
# un API Gateway unico, se setea NEXT_PUBLIC_API_GATEWAY_URL y se omiten las
# de abajo (config.ts cae al gateway como fallback).

# BC-13 Activos
NEXT_PUBLIC_ACTIVOS_API_URL=http://localhost:3001

# Combustible
NEXT_PUBLIC_COMBUSTIBLE_API_URL=http://localhost:3003

# Socio de Negocios
NEXT_PUBLIC_SOCIO_NEGOCIOS_API_URL=http://localhost:8080/api

# CS-Configuracion General
NEXT_PUBLIC_CONFIGURACION_GENERAL_API_URL=http://localhost:8080/api

# BC-03 Comercial (Gestion Comercial)
NEXT_PUBLIC_COMERCIAL_API_URL=http://localhost:3000/api/v1


# -----------------------------------------------------------------------------
# API Gateway (opcional)
# -----------------------------------------------------------------------------
# Si esta seteada, sirve como fallback cuando una URL especifica de BC no esta
# configurada. Util cuando todo el trafico pasa por un gateway unico.
#
# NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:8080
